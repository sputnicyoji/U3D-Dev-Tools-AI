{
  "name": "findElement",
  "description": "Finds elements (paragraphs, tables, etc.) based on various criteria. (Not Implemented)",
  "inputSchema": {
    "type": "object",
    "properties": {
      "documentId": {
        "type": "string",
        "description": "The ID of the Google Document (from the URL)."
      },
      "textQuery": {
        "type": "string"
      },
      "elementType": {
        "type": "string",
        "enum": [
          "paragraph",
          "table",
          "list",
          "image"
        ]
      }
    },
    "required": [
      "documentId"
    ],
    "additionalProperties": false,
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}