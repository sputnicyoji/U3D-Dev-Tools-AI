{
  "name": "applyTextStyle",
  "description": "Applies character-level formatting (bold, color, font, etc.) to a specific range or found text.",
  "inputSchema": {
    "type": "object",
    "properties": {
      "documentId": {
        "type": "string",
        "description": "The ID of the Google Document (from the URL)."
      },
      "target": {
        "anyOf": [
          {
            "type": "object",
            "properties": {
              "startIndex": {
                "type": "integer",
                "minimum": 1,
                "description": "The starting index of the text range (inclusive, starts from 1)."
              },
              "endIndex": {
                "type": "integer",
                "minimum": 1,
                "description": "The ending index of the text range (exclusive)."
              }
            },
            "required": [
              "startIndex",
              "endIndex"
            ],
            "additionalProperties": false
          },
          {
            "type": "object",
            "properties": {
              "textToFind": {
                "type": "string",
                "minLength": 1,
                "description": "The exact text string to locate."
              },
              "matchInstance": {
                "type": "integer",
                "minimum": 1,
                "default": 1,
                "description": "Which instance of the text to target (1st, 2nd, etc.). Defaults to 1."
              }
            },
            "required": [
              "textToFind"
            ],
            "additionalProperties": false
          }
        ],
        "description": "Specify the target range either by start/end indices or by finding specific text."
      },
      "style": {
        "type": "object",
        "properties": {
          "bold": {
            "type": "boolean",
            "description": "Apply bold formatting."
          },
          "italic": {
            "type": "boolean",
            "description": "Apply italic formatting."
          },
          "underline": {
            "type": "boolean",
            "description": "Apply underline formatting."
          },
          "strikethrough": {
            "type": "boolean",
            "description": "Apply strikethrough formatting."
          },
          "fontSize": {
            "type": "number",
            "minimum": 1,
            "description": "Set font size (in points, e.g., 12)."
          },
          "fontFamily": {
            "type": "string",
            "description": "Set font family (e.g., \"Arial\", \"Times New Roman\")."
          },
          "foregroundColor": {
            "type": "string",
            "description": "Set text color using hex format (e.g., \"#FF0000\")."
          },
          "backgroundColor": {
            "type": "string",
            "description": "Set text background color using hex format (e.g., \"#FFFF00\")."
          },
          "linkUrl": {
            "type": "string",
            "format": "uri",
            "description": "Make the text a hyperlink pointing to this URL."
          }
        },
        "additionalProperties": false,
        "description": "The text styling to apply."
      }
    },
    "required": [
      "documentId",
      "target",
      "style"
    ],
    "additionalProperties": false,
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}