{
  "name": "createGmailFilter",
  "description": "Create a Gmail filter for automatic message processing.",
  "inputSchema": {
    "type": "object",
    "properties": {
      "from": {
        "type": "string",
        "description": "Match sender email."
      },
      "to": {
        "type": "string",
        "description": "Match recipient email."
      },
      "subject": {
        "type": "string",
        "description": "Match subject contains."
      },
      "query": {
        "type": "string",
        "description": "Gmail search query for criteria."
      },
      "hasAttachment": {
        "type": "boolean",
        "description": "Match messages with attachments."
      },
      "addLabelIds": {
        "type": "array",
        "items": {
          "type": "string"
        },
        "description": "Label IDs to add to matching messages."
      },
      "removeLabelIds": {
        "type": "array",
        "items": {
          "type": "string"
        },
        "description": "Label IDs to remove from matching messages."
      }
    },
    "additionalProperties": false,
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}