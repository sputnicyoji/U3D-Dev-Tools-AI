{
  "name": "updateCalendarEvent",
  "description": "Update an existing calendar event.",
  "inputSchema": {
    "type": "object",
    "properties": {
      "eventId": {
        "type": "string",
        "description": "The event ID to update."
      },
      "calendarId": {
        "type": "string",
        "default": "primary",
        "description": "Calendar ID (default: primary)."
      },
      "summary": {
        "type": "string",
        "description": "New event title."
      },
      "description": {
        "type": "string",
        "description": "New event description."
      },
      "location": {
        "type": "string",
        "description": "New event location."
      },
      "start": {
        "type": "object",
        "properties": {
          "dateTime": {
            "type": "string",
            "description": "RFC3339 timestamp for timed events (e.g., \"2024-01-15T09:00:00-08:00\")."
          },
          "date": {
            "type": "string",
            "description": "Date for all-day events (YYYY-MM-DD format)."
          },
          "timeZone": {
            "type": "string",
            "description": "Time zone (e.g., \"America/Los_Angeles\")."
          }
        },
        "additionalProperties": false,
        "description": "New start time."
      },
      "end": {
        "$ref": "#/properties/start",
        "description": "New end time."
      },
      "attendees": {
        "type": "array",
        "items": {
          "type": "string"
        },
        "description": "Updated attendee emails (replaces existing)."
      },
      "sendUpdates": {
        "type": "string",
        "enum": [
          "all",
          "externalOnly",
          "none"
        ],
        "default": "none",
        "description": "Send notifications about the update."
      }
    },
    "required": [
      "eventId"
    ],
    "additionalProperties": false,
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}