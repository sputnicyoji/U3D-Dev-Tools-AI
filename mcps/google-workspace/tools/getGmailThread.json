{
  "name": "getGmailThread",
  "description": "Get a complete email thread/conversation with all messages.",
  "inputSchema": {
    "type": "object",
    "properties": {
      "threadId": {
        "type": "string",
        "description": "The thread ID to retrieve."
      },
      "format": {
        "type": "string",
        "enum": [
          "full",
          "metadata",
          "minimal"
        ],
        "default": "full",
        "description": "Format for messages in thread."
      }
    },
    "required": [
      "threadId"
    ],
    "additionalProperties": false,
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}