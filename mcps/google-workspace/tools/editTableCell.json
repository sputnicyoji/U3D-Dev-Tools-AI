{
  "name": "editTableCell",
  "description": "Edits the content and/or basic style of a specific table cell. Requires knowing table start index.",
  "inputSchema": {
    "type": "object",
    "properties": {
      "documentId": {
        "type": "string",
        "description": "The ID of the Google Document (from the URL)."
      },
      "tableStartIndex": {
        "type": "integer",
        "minimum": 1,
        "description": "The starting index of the TABLE element itself (tricky to find, may require reading structure first)."
      },
      "rowIndex": {
        "type": "integer",
        "minimum": 0,
        "description": "Row index (0-based)."
      },
      "columnIndex": {
        "type": "integer",
        "minimum": 0,
        "description": "Column index (0-based)."
      },
      "textContent": {
        "type": "string",
        "description": "Optional: New text content for the cell. Replaces existing content."
      },
      "textStyle": {
        "type": "object",
        "properties": {
          "bold": {
            "type": "boolean",
            "description": "Apply bold formatting."
          },
          "italic": {
            "type": "boolean",
            "description": "Apply italic formatting."
          },
          "underline": {
            "type": "boolean",
            "description": "Apply underline formatting."
          },
          "strikethrough": {
            "type": "boolean",
            "description": "Apply strikethrough formatting."
          },
          "fontSize": {
            "type": "number",
            "minimum": 1,
            "description": "Set font size (in points, e.g., 12)."
          },
          "fontFamily": {
            "type": "string",
            "description": "Set font family (e.g., \"Arial\", \"Times New Roman\")."
          },
          "foregroundColor": {
            "type": "string",
            "description": "Set text color using hex format (e.g., \"#FF0000\")."
          },
          "backgroundColor": {
            "type": "string",
            "description": "Set text background color using hex format (e.g., \"#FFFF00\")."
          },
          "linkUrl": {
            "type": "string",
            "format": "uri",
            "description": "Make the text a hyperlink pointing to this URL."
          }
        },
        "additionalProperties": false,
        "description": "Optional: Text styles to apply."
      },
      "paragraphStyle": {
        "type": "object",
        "properties": {
          "alignment": {
            "type": "string",
            "enum": [
              "START",
              "END",
              "CENTER",
              "JUSTIFIED"
            ],
            "description": "Paragraph alignment. START=left for LTR languages, END=right for LTR languages."
          },
          "indentStart": {
            "type": "number",
            "minimum": 0,
            "description": "Left indentation in points."
          },
          "indentEnd": {
            "type": "number",
            "minimum": 0,
            "description": "Right indentation in points."
          },
          "spaceAbove": {
            "type": "number",
            "minimum": 0,
            "description": "Space before the paragraph in points."
          },
          "spaceBelow": {
            "type": "number",
            "minimum": 0,
            "description": "Space after the paragraph in points."
          },
          "namedStyleType": {
            "type": "string",
            "enum": [
              "NORMAL_TEXT",
              "TITLE",
              "SUBTITLE",
              "HEADING_1",
              "HEADING_2",
              "HEADING_3",
              "HEADING_4",
              "HEADING_5",
              "HEADING_6"
            ],
            "description": "Apply a built-in named paragraph style (e.g., HEADING_1)."
          },
          "keepWithNext": {
            "type": "boolean",
            "description": "Keep this paragraph together with the next one on the same page."
          }
        },
        "additionalProperties": false,
        "description": "Optional: Paragraph styles (like alignment) to apply."
      }
    },
    "required": [
      "documentId",
      "tableStartIndex",
      "rowIndex",
      "columnIndex"
    ],
    "additionalProperties": false,
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}