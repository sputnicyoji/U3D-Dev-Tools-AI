{
  "name": "createDocument",
  "description": "Creates a new Google Document.",
  "inputSchema": {
    "type": "object",
    "properties": {
      "title": {
        "type": "string",
        "minLength": 1,
        "description": "Title for the new document."
      },
      "parentFolderId": {
        "type": "string",
        "description": "ID of folder where document should be created. If not provided, creates in Drive root."
      },
      "initialContent": {
        "type": "string",
        "description": "Initial text content to add to the document."
      }
    },
    "required": [
      "title"
    ],
    "additionalProperties": false,
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}