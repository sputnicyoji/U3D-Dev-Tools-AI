    "properties": {
      "eventId": {
        "type": "string",
        "description": "The event ID to retrieve."
      },
      "calendarId": {
        "type": "string",
        "default": "primary",
        "description": "Calendar ID (default: primary)."
      }
    },
    "required": [
      "eventId"
    ],
    "additionalProperties": false,
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}