{
  "name": "applyParagraphStyle",
  "description": "Applies paragraph-level formatting (alignment, spacing, named styles like Heading 1) to the paragraph(s) containing specific text, an index, or a range.",
  "inputSchema": {
    "type": "object",
    "properties": {
      "documentId": {
        "type": "string",
        "description": "The ID of the Google Document (from the URL)."
      },
      "target": {
        "anyOf": [
          {
            "type": "object",
            "properties": {
              "startIndex": {
                "type": "integer",
                "minimum": 1,
                "description": "The starting index of the text range (inclusive, starts from 1)."
              },
              "endIndex": {
                "type": "integer",
                "minimum": 1,
                "description": "The ending index of the text range (exclusive)."
              }
            },
            "required": [
              "startIndex",
              "endIndex"
            ],
            "additionalProperties": false
          },
          {
            "type": "object",
            "properties": {
              "textToFind": {
                "type": "string",
                "minLength": 1,
                "description": "The exact text string to locate."
              },
              "matchInstance": {
                "type": "integer",
                "minimum": 1,
                "default": 1,
                "description": "Which instance of the text to target (1st, 2nd, etc.). Defaults to 1."
              }
            },
            "required": [
              "textToFind"
            ],
            "additionalProperties": false
          },
          {
            "type": "object",
            "properties": {
              "indexWithinParagraph": {
                "type": "integer",
                "minimum": 1,
                "description": "An index located anywhere within the target paragraph."
              }
            },
            "required": [
              "indexWithinParagraph"
            ],
            "additionalProperties": false
          }
        ],
        "description": "Specify the target paragraph either by start/end indices, by finding text within it, or by providing an index within it."
      },
      "style": {
        "type": "object",
        "properties": {
          "alignment": {
            "type": "string",
            "enum": [
              "START",
              "END",
              "CENTER",
              "JUSTIFIED"
            ],
            "description": "Paragraph alignment. START=left for LTR languages, END=right for LTR languages."
          },
          "indentStart": {
            "type": "number",
            "minimum": 0,
            "description": "Left indentation in points."
          },
          "indentEnd": {
            "type": "number",
            "minimum": 0,
            "description": "Right indentation in points."
          },
          "spaceAbove": {
            "type": "number",
            "minimum": 0,
            "description": "Space before the paragraph in points."
          },
          "spaceBelow": {
            "type": "number",
            "minimum": 0,
            "description": "Space after the paragraph in points."
          },
          "namedStyleType": {
            "type": "string",
            "enum": [
              "NORMAL_TEXT",
              "TITLE",
              "SUBTITLE",
              "HEADING_1",
              "HEADING_2",
              "HEADING_3",
              "HEADING_4",
              "HEADING_5",
              "HEADING_6"
            ],
            "description": "Apply a built-in named paragraph style (e.g., HEADING_1)."
          },
          "keepWithNext": {
            "type": "boolean",
            "description": "Keep this paragraph together with the next one on the same page."
          }
        },
        "additionalProperties": false,
        "description": "The paragraph styling to apply."
      }
    },
    "required": [
      "documentId",
      "target",
      "style"
    ],
    "additionalProperties": false,
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}