{
  "name": "getGmailAttachment",
  "description": "Download an attachment from a Gmail message. Returns base64-encoded data.",
  "inputSchema": {
    "type": "object",
    "properties": {
      "messageId": {
        "type": "string",
        "description": "The message ID containing the attachment."
      },
      "attachmentId": {
        "type": "string",
        "description": "The attachment ID (from getGmailMessage)."
      }
    },
    "required": [
      "messageId",
      "attachmentId"
    ],
    "additionalProperties": false,
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}